PORT=3000
NLP_SERVICE_URL=http://127.0.0.1:8000
MAX_FILE_SIZE_MB=10
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=120000
NODE_ENV=development

# CORS — comma-separated origins (use * to allow all)
ALLOWED_ORIGINS=*

# API Key — leave empty to skip auth in development
API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
